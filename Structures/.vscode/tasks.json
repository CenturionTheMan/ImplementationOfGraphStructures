{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++ build project no optimization",
      "command": "/usr/bin/g++",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-O0",
        "-I${workspaceFolder}/src/headers",
        "${workspaceFolder}/src/*.cpp",
        "${workspaceFolder}/src/impl/*.cpp",
        "-o",
        "${workspaceFolder}/main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build entire project with g++, no optimization"
    },
    {
      "type": "cppbuild",
      "label": "C/C++: cl.exe build project no optimization",
      "command": "cl.exe",
      "args": [
        "/Zi",
        "/Od",
        "/EHsc",
        "/nologo",
        "/I${workspaceFolder}\\src\\headers",
        "/Fe${workspaceFolder}\\main.exe",
        "${workspaceFolder}\\src\\*.cpp",
        "${workspaceFolder}\\src\\impl\\*.cpp"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Build project with cl.exe without optimization"
    }
  ],
  "version": "2.0.0"
}
